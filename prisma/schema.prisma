generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Media {
  id          String   @id @default(cuid())
  tmdbId      Int      // TMDB movie or TV ID
  type        String   // "movie" | "tv"
  title       String
  overview    String?
  posterPath  String?
  releaseDate String?
  runtime     Int?     // Movie runtime in minutes (from TMDB)
  status      String   // "yet_to_start" | "in_progress" | "finished" | "rewatch"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  // For TV: optional progress (e.g. "Season 2, Episode 5")
  progressNote   String?
  // For TV: total season count (from TMDB or set manually)
  totalSeasons   Int?
  // For TV: per-season status. JSON array: [{ "season": 1, "status": "completed" }, ...]
  seasonProgress Json?
  // Streaming service: "Apple TV", "Netflix", "Plex", "HBO", "Prime", "Comedy Specials", etc.
  streamingService String?
  // Viewer: "wife" | "both" | "me"
  viewer String?
  // Custom sort order (lower = first). Default 0; reorder updates this.
  sortOrder Int @default(0)

  playbackEvents PlaybackEvent[]

  @@index([tmdbId, type])
  @@index([status])
  @@index([type])
  @@index([updatedAt])
  @@index([streamingService])
  @@index([viewer])
  @@index([sortOrder])
}

/// Append-only Plex webhook history (e.g. media.scrobble). Survives deleting episodes or titles in Plex;
/// WatchBox `mediaId` is cleared if you remove the show from WatchBox (TMDB fields remain).
model PlaybackEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  event     String

  mediaId String?
  media   Media?  @relation(fields: [mediaId], references: [id], onDelete: SetNull)

  tmdbId    Int?
  mediaKind String?

  title         String?
  showTitle     String?
  season        Int?
  episode       Int?
  year          Int?

  ratingKey            String?
  grandparentRatingKey String?
  guid                 String?

  accountTitle String?
  playerTitle  String?

  @@index([mediaId])
  @@index([tmdbId, mediaKind])
  @@index([createdAt])
}
