DATABASE_URL="file:./dev.db"
TMDB_API_KEY=your_tmdb_api_key_here

# Optional: Plex Media Server (same LAN as this app, or reachable URL)
# PLEX_SERVER_URL=http://192.168.1.10:32400
# PLEX_TOKEN=see README — X-Plex-Token
# Optional: shared secret for POST /api/plex/webhook?secret=...
# PLEX_WEBHOOK_SECRET=random_long_string
# Optional: log raw webhook JSON body to stdout (docker logs / debugging)
# PLEX_WEBHOOK_LOG_RAW=true
# Optional: only record/show playback for these Plex usernames (Account.title from webhooks), comma-separated
# PLEX_WEBHOOK_ALLOWED_ACCOUNTS=carterja11

# Optional: override displayed build string (otherwise package version + GIT_SHA at Docker build)
# NEXT_PUBLIC_APP_VERSION=0.1.0+custom
