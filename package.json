{
  "name": "watchbox",
  "version": "0.1.2",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:stable": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "dev:lan": "next dev --turbopack -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "bash scripts/run-e2e.sh",
    "test:e2e:smoke": "bash scripts/run-e2e.sh --grep @smoke",
    "test:e2e:ui": "bash scripts/run-e2e.sh --ui",
    "test:e2e:debug": "bash scripts/run-e2e.sh --debug",
    "playwright:install": "PLAYWRIGHT_BROWSERS_PATH=.pw-browsers playwright install --with-deps chromium",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:backfill-viewer": "node scripts/backfill-viewer.mjs",
    "db:studio": "prisma studio",
    "generate-icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "6.19.2",
    "embla-carousel-react": "^8.6.0",
    "fast-xml-parser": "^5.5.9",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.460.0",
    "next": "^15",
    "react": "^19",
    "react-dom": "^19",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "^15",
    "jsdom": "^28.1.0",
    "postcss": "^8",
    "prisma": "6.19.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "to-ico": "^1.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
